# DATABASE_URL=postgresql://user@localhost:5432/your_dev_db
# TEST_DATABASE_URL=postgresql://user@localhost:5432/your_test_db
# PRISMA_HIDE_UPDATE_MESSAGE=true
# LOG_LEVEL=trace

# Music platform API credentials (api side only)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# YOUTUBE_API_KEY=
# SOUNDCLOUD_CLIENT_ID=
# SOUNDCLOUD_CLIENT_SECRET=

# SendGrid — sends the "reset your password" email (api side only).
# Without SENDGRID_API_KEY set, forgotPassword logs the reset link instead
# of emailing it, so the flow stays usable in dev.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@soundround.app
# APP_URL=http://localhost:8920
