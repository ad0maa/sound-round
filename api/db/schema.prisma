// Don't forget to tell Prisma about your edits to this file using
// `yarn cedar prisma migrate dev` or `yarn cedar prisma db push`.
// `migrate` is like committing while `push` is for prototyping.
// Read more about both here:
// https://www.prisma.io/docs/orm/prisma-migrate

datasource db {
  provider = "postgresql"
}

generator client {
  provider               = "prisma-client-js"
  output                 = "./generated/prisma"
  generatedFileExtension = "js"
}

enum Role {
  creator
  admin
  player
}

enum RoundState {
  upcoming
  submitting
  voting
  results
}

enum Platform {
  spotify
  soundcloud
  youtube
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  displayName         String
  avatarUrl           String?
  hashedPassword      String
  salt                String
  resetToken          String?
  resetTokenExpiresAt DateTime?
  isDemo              Boolean        @default(false)
  demoExpiresAt       DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  memberships         LeagueMember[]
  createdLeagues      League[]       @relation("LeagueCreator")
  submissions         Submission[]
  votes               Vote[]
  comments            Comment[]

  @@index([isDemo, demoExpiresAt])
}

model League {
  id                      String         @id @default(uuid())
  name                    String
  description             String?
  creatorId               String
  creator                 User           @relation("LeagueCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  isPublic                Boolean        @default(false)
  inviteCode              String?        @unique
  maxPlayers              Int            @default(20)
  upvotesPerRound         Int            @default(10)
  downvotesEnabled        Boolean        @default(false)
  downvotesPerRound       Int            @default(0)
  maxPointsPerSong        Int?
  uniqueArtists           Boolean        @default(false)
  totalRounds             Int            @default(10)
  submissionDeadlineHours Int            @default(72)
  votingDeadlineHours     Int            @default(48)
  // Optional scheduled start — round 1 opens lazily once this passes.
  startsAt                DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  members                 LeagueMember[]
  rounds                  Round[]
}

model LeagueMember {
  leagueId String
  userId   String
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role     @default(player)
  joinedAt DateTime @default(now())

  @@id([leagueId, userId])
}

model Round {
  id               String       @id @default(uuid())
  leagueId         String
  league           League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roundNumber      Int
  theme            String
  description      String?
  state            RoundState   @default(upcoming)
  submissionsOpen  DateTime?
  submissionsClose DateTime?
  votingClose      DateTime?
  // Per-round overrides; fall back to the league's deadline-hours defaults.
  submissionDurationHours Int?
  votingDurationHours     Int?
  songsPerPlayer   Int          @default(1)
  createdAt        DateTime     @default(now())
  submissions      Submission[]
  votes            Vote[]
  comments         Comment[]

  @@unique([leagueId, roundNumber])
}

model Submission {
  id              String   @id @default(uuid())
  roundId         String
  round           Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        Platform
  platformTrackId String
  trackUrl        String
  trackName       String
  artistName      String
  albumName       String?
  artworkUrl      String?
  durationMs      Int?
  submittedAt     DateTime @default(now())
  votes           Vote[]

  @@unique([roundId, userId, platformTrackId])
}

model Vote {
  id           String     @id @default(uuid())
  roundId      String
  round        Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voterId      String
  voter        User       @relation(fields: [voterId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  // signed: positive = upvote, negative = downvote
  points       Int
  createdAt    DateTime   @default(now())

  @@unique([roundId, voterId, submissionId])
}

// Planned feature carried over from the original design — no SDL/service yet.
model Comment {
  id        String   @id @default(uuid())
  roundId   String
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}
